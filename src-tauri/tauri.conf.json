{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Capsule",
  "version": "0.16.2",
  "identifier": "com.local.capsule",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Capsule",
        "width": 1440,
        "height": 960,
        "minWidth": 1040,
        "minHeight": 720,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.ico", "icons/icon.png"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZEMzQzOENDMTE4NUYyMDEKUldRQjhvVVJ6RGcwYlpFenI1cFlWcG1wckRXZjJuOUozRDVYYjY5emJ3R2NYTnFpQTd3WXcwcEgK",
      "endpoints": [
        "https://github.com/soundtrackgeek/capsule_tauri/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
