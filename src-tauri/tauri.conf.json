{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Capsule",
  "version": "0.7.13",
  "identifier": "com.local.capsule",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1430",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Capsule",
        "width": 1440,
        "height": 960,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
